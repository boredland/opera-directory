  {
    "id": "dutch-national-opera/lennox/2026-27",
    "work_slug": "bnnyhunna/lennox",
    "house_slug": "dutch-national-opera",
    "premiere_season": "2026/27",
    "is_revival": false,
    "detail_url": "https://www.operaballet.nl/de-nationale-opera/2026-2027/lennox",
    "image_url": {
      "@type": "ImageObject",
      "representativeOfPage": "True",
      "url": "https://www.operaballet.nl/sites/default/files/styles/1200x1200/public/images/DNO/seizoen%2026-27/Lennox/Lennox_%C2%A9Michiel-Spijkers.jpg?h=02484828&itok=9_aK9QJg"
    },
    "synopsis": "Lennox weet dat zijn vader ziek is, maar niemand vertelt hem wat er speelt. Wanneer zijn vader op een dag zijn geluksketting vergeet mee te nemen naar het ziekenhuis, besluit Lennox hem samen met zijn beste vriendin achterna te gaan. Wat volgt is een energieke hiphop-opera over familie, vriendschap en dingen durven doen. RIGHTABOUTNOW INC. en De Nationale Opera bewerkten het boek Lennox en de gouden sikkel van Zindzi Zevenbergen tot een sprankelende jeugdopera, op nieuwe muziek van Bnnyhunna.",
    "creative_team": [
      {
        "person_slug": "iris-elstrodt",
        "function": "costume-designer"
