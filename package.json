{
  "name": "opera-directory",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "test": "bun test",
    "scrape": "bun packages/ingest/src/index.ts",
    "scrape-raw": "bun packages/ingest/src/index.ts scrape-raw",
    "ingest-raw": "bun packages/ingest/src/index.ts ingest-raw",
    "validate": "bun packages/ingest/src/index.ts validate",
    "typecheck": "bun --filter '*' typecheck",
    "lint": "biome check .",
    "format": "biome format --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@types/bun": "^1.2.0",
    "playwright-core": "^1.60.0",
    "typescript": "^5.9.3"
  }
}
